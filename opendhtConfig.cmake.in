@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_opendht_msvc @_OPENDHT_MSVC@)
set(_opendht_use_pkgconfig @_OPENDHT_USE_PKGCONFIG@)
set(_opendht_shared @_OPENDHT_SHARED@)
set(_opendht_tools @_OPENDHT_TOOLS@)
set(_opendht_http @_OPENDHT_HTTP@)
set(_opendht_proxy_openssl @_OPENDHT_PROXY_OPENSSL@)
set(_opendht_peer_discovery @_OPENDHT_PEER_DISCOVERY@)
set(_opendht_io_uring @_OPENDHT_IO_URING@)

if(_opendht_msvc)
    # MSVC/vcpkg path
    if(NOT _opendht_shared)
        find_dependency(unofficial-argon2 CONFIG)
        # Recreate nettle/hogweed/tasn1 imported targets
        if(NOT TARGET nettle_lib)
            find_library(_opendht_NETTLE_LIBRARY NAMES nettle libnettle REQUIRED)
            find_path(_opendht_NETTLE_INCLUDE_DIR nettle/aes.h REQUIRED)
            add_library(nettle_lib STATIC IMPORTED)
            set_target_properties(nettle_lib PROPERTIES
                IMPORTED_LOCATION "${_opendht_NETTLE_LIBRARY}"
                INTERFACE_INCLUDE_DIRECTORIES "${_opendht_NETTLE_INCLUDE_DIR}"
            )
        endif()
        if(NOT TARGET hogweed_lib)
            find_library(_opendht_HOGWEED_LIBRARY NAMES hogweed REQUIRED)
            add_library(hogweed_lib STATIC IMPORTED)
            set_target_properties(hogweed_lib PROPERTIES
                IMPORTED_LOCATION "${_opendht_HOGWEED_LIBRARY}"
            )
        endif()
        if(NOT TARGET tasn1_lib)
            find_library(_opendht_TASN_LIBRARY NAMES tasn1 REQUIRED)
            add_library(tasn1_lib STATIC IMPORTED)
            set_target_properties(tasn1_lib PROPERTIES
                IMPORTED_LOCATION "${_opendht_TASN_LIBRARY}"
            )
        endif()
    endif()
    find_dependency(GnuTLS)
    find_dependency(msgpack-cxx CONFIG)
    find_dependency(jsoncpp CONFIG)
    find_dependency(simdutf CONFIG)
    find_dependency(fmt CONFIG)
    if(_opendht_tools)
        find_dependency(unofficial-readline-win32 CONFIG)
    endif()
    if(_opendht_http)
        find_dependency(restinio CONFIG)
        find_dependency(llhttp CONFIG)
        if(_opendht_proxy_openssl)
            find_dependency(OpenSSL)
        endif()
    endif()
elseif(_opendht_use_pkgconfig)
    # PkgConfig path
    find_dependency(PkgConfig)
    pkg_search_module(GnuTLS REQUIRED IMPORTED_TARGET gnutls)
    pkg_search_module(fmt REQUIRED IMPORTED_TARGET fmt)
    pkg_search_module(Jsoncpp IMPORTED_TARGET jsoncpp)
    if(NOT _opendht_shared)
        pkg_search_module(argon2 REQUIRED IMPORTED_TARGET libargon2)
        pkg_search_module(Nettle REQUIRED IMPORTED_TARGET nettle)
        pkg_search_module(simdutf IMPORTED_TARGET simdutf)
    endif()
    if(_opendht_http OR _opendht_peer_discovery)
        pkg_search_module(asio IMPORTED_TARGET asio)
    endif()
    if(_opendht_http)
        pkg_search_module(LLHTTP IMPORTED_TARGET llhttp libllhttp)
    endif()
    if(_opendht_proxy_openssl)
        pkg_search_module(OPENSSL REQUIRED IMPORTED_TARGET openssl)
    endif()
    if(_opendht_io_uring)
        pkg_search_module(liburing IMPORTED_TARGET liburing)
    endif()
else()
    # Non-pkgconfig Unix path (find_package)
    find_dependency(GnuTLS)
    find_dependency(jsoncpp CONFIG)
    find_dependency(fmt CONFIG)
    if(_opendht_http)
        find_dependency(llhttp CONFIG)
        if(_opendht_proxy_openssl)
            find_dependency(OpenSSL)
        endif()
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/opendhtTargets.cmake")

check_required_components(opendht)
